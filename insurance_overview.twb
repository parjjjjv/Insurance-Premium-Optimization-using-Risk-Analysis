          <datasource-dependencies datasource='federated.0d5o86z0xe7iei12b6h4b0odrke1'>
            <column caption='Alcohol Consumption' datatype='string' name='[Alcohol_Consumption]' role='dimension' type='nominal' />
            <column aggregation='Sum' caption='Blood Pressure Systolic' datatype='integer' name='[Blood_Pressure_Systolic]' role='dimension' type='ordinal' />
            <column caption='BP Category' datatype='string' name='[Calculation_2244200046447706112]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Blood_Pressure_Systolic] &lt; 120 THEN &quot;Normal&quot;&#13;&#10;ELSEIF [Blood_Pressure_Systolic] &lt;= 139 THEN &quot;Elevated&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
            </column>
            <column caption='Smoking Risk' datatype='integer' name='[Calculation_2244200046449971201]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Smoking_Status] = &quot;Current&quot; THEN 1250&#13;&#10;ELSEIF [Smoking_Status] = &quot;Former&quot; THEN 500&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Alcohol Risk' datatype='integer' name='[Calculation_2244200046450200578]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Alcohol_Consumption] = &quot;Heavy&quot; THEN 1250&#13;&#10;ELSEIF [Alcohol_Consumption] = &quot;Moderate&quot; THEN 500&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Diabetes Risk' datatype='integer' name='[Calculation_2244200046450348035]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Family_History_of_Diabetes] = 1 THEN 750&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='BP Risk' datatype='integer' name='[Calculation_2244200046450651140]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_2244200046447706112] = &quot;High&quot; THEN 1000&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Final Premium' datatype='integer' name='[Calculation_2244200046450757637]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='5000 &#13;&#10;+ [Calculation_2244200046449971201]&#13;&#10;+ [Calculation_2244200046450200578]&#13;&#10;+ [Calculation_2244200046450348035]&#13;&#10;+ [Calculation_2244200046450651140]' />
